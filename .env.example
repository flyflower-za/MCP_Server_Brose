# MCP服务器环境配置文件
# 这是你的实际配置文件

# 🔧 服务器配置 - 修改这里来改变端口！
MCP_HOST=0.0.0.0
MCP_PORT=51234

# 🐛 调试模式
MCP_DEBUG=false

# 📋 日志配置
LOG_LEVEL=INFO
LOG_FILE=mcp_server.log

# ⏱️ 请求配置
REQUEST_TIMEOUT=30

# 🔒 SSL配置
SSL_VERIFY=false

DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=mcp12345
# 是否启用Dashboard认证（true=需要登录，false=无需登录直接访问）
DASHBOARD_AUTH_ENABLED=true