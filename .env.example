# MCP服务器环境配置文件
# 这是你的实际配置文件

# 🔧 服务器配置 - 修改这里来改变端口！
MCP_HOST=0.0.0.0
MCP_PORT=51234

# 🐛 调试模式
MCP_DEBUG=false

# 📋 日志配置
LOG_LEVEL=INFO
LOG_FILE=mcp_server.log

# ⏱️ 请求配置
REQUEST_TIMEOUT=30

# 🔒 SSL配置
SSL_VERIFY=false

DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=mcp12345
# 是否启用Dashboard认证（true=需要登录，false=无需登录直接访问）
DASHBOARD_AUTH_ENABLED=true
# Dashboard自动刷新间隔（秒），建议值：15-300，默认120秒
DASHBOARD_REFRESH_INTERVAL=120

# 🔑 JWT密钥配置（生产环境建议设置复杂值）
JWT_SECRET_KEY=your-secret-key-change-in-production

# ⚙️ 进程管理配置
# PROCESS_BASE_PORT 会自动设置为 MCP_PORT + 1（如：51234 → 51235）
# 如需自定义，可取消下方注释并修改
# PROCESS_BASE_PORT=51235
PROCESS_MAX_RESTART=3              # 最大自动重启次数
PROCESS_AUTO_RESTART=true          # 自动重启故障进程
PROCESS_START_TIMEOUT=30           # 进程启动超时（秒）

# 🆕 MCP服务器模块配置
# 控制各个MCP服务器模块的启用/禁用状态（true=启用，false=禁用）
# 系统会自动启动以下设置为 true 的模块
ENABLE_PDF_EXTRACTOR=true        # PDF内容提取
ENABLE_QRCODE_READER=true         # 二维码识别
ENABLE_PDF_SIGNATURE_VERIFIER=false  # PDF签章验证 ⚠️ macOS兼容性问题，默认禁用
