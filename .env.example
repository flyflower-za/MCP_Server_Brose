# MCP服务器环境配置文件

# 🔧 服务器配置
MCP_HOST=0.0.0.0
MCP_PORT=51234

# 🐛 调试模式
MCP_DEBUG=false

# 📋 日志配置
LOG_LEVEL=INFO
LOG_FILE=mcp_server.log
LOG_MAX_BYTES=10485760      # 单个日志文件最大10MB
LOG_BACKUP_COUNT=5          # 保留5个备份文件
LOG_KEEP_DAYS=7            # 清理7天前的日志

# ⏱️ 请求配置
REQUEST_TIMEOUT=30

# 🔒 SSL配置
SSL_VERIFY=false

# 🔐 Dashboard 认证配置
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your-password
DASHBOARD_AUTH_ENABLED=true

# 🕐 Dashboard自动刷新间隔（秒）
DASHBOARD_REFRESH_INTERVAL=120

# 🔑 JWT密钥配置（生产环境建议设置复杂值）
JWT_SECRET_KEY=your-permanent-api-key-change-this

# 🔧 永久API Key（用于插件集成，长期有效）
API_KEY=your-permanent-api-key-change-this

# ⚙️ 进程管理配置
PROCESS_BASE_PORT=51235
PROCESS_MAX_RESTART=3
PROCESS_AUTO_RESTART=true

# 进程启动超时配置（增加到30秒，解决pdf_signature_verifier启动慢的问题）
PROCESS_START_TIMEOUT=30

# 🆕 MCP服务器模块配置
# 控制各个MCP服务器模块的启用/禁用状态
ENABLE_PDF_EXTRACTOR=true
ENABLE_QRCODE_READER=true
ENABLE_PDF_SIGNATURE_VERIFIER=true  # ⚠️ macOS安全机制兼容性问题，默认禁用
