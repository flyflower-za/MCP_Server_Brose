# MCP服务器环境配置文件
# 复制此文件为 .env 并修改相应配置

# 🔧 服务器配置
MCP_HOST=0.0.0.0
MCP_PORT=51234

# 🐛 调试模式
MCP_DEBUG=false

# 📋 日志配置
LOG_LEVEL=INFO
LOG_FILE=mcp_server.log

# ⏱️ 请求配置
REQUEST_TIMEOUT=120

# 🔒 SSL配置
SSL_VERIFY=false

# 🔐 Dashboard 认证配置
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=pdf12345
# 是否启用Dashboard认证（true=需要登录，false=无需登录直接访问）
DASHBOARD_AUTH_ENABLED=true

# ⚙️ 进程管理配置
# PROCESS_BASE_PORT 会自动设置为 MCP_PORT + 1（如：51234 → 51235）
# 如需自定义，可取消下方注释并修改
# PROCESS_BASE_PORT=51235
PROCESS_MAX_RESTART=3
PROCESS_HEALTH_CHECK_INTERVAL=30
PROCESS_AUTO_RESTART=true
